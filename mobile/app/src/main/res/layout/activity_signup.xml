<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- ════════════════════════════════════════ -->
        <!-- HEADER                                   -->
        <!-- ════════════════════════════════════════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#0A3D6B">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="24dp"
                android:paddingRight="24dp">

                <TextView
                    android:id="@+id/tvBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="&lt;"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="36dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Créer un compte"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="UrgencePro — Accès professionnel"
                        android:textColor="#B3D4F0"
                        android:textSize="12sp" />

                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>

        <!-- ════════════════════════════════════════ -->
        <!-- CARD FORMULAIRE                          -->
        <!-- ════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- ══════════════════════════════════ -->
                <!-- SECTION 1 : Infos personnelles     -->
                <!-- ══════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informations personnelles"
                    android:textColor="#0A3D6B"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"
                    android:background="#1976D2" />

                <!-- Nom + Prénom -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nom"
                            android:textColor="#374151"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/input_background"
                            android:gravity="center_vertical"
                            android:paddingLeft="12dp"
                            android:paddingRight="12dp">

                            <EditText
                                android:id="@+id/etNom"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:inputType="textPersonName"
                                android:singleLine="true"
                                android:textColor="#1A1A2E"
                                android:textColorHint="#9CA3AF"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Prénom"
                            android:textColor="#374151"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/input_background"
                            android:gravity="center_vertical"
                            android:paddingLeft="12dp"
                            android:paddingRight="12dp">

                            <EditText
                                android:id="@+id/etPrenom"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:inputType="textPersonName"
                                android:singleLine="true"
                                android:textColor="#1A1A2E"
                                android:textColorHint="#9CA3AF"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Adresse email professionnelle"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/input_background"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp">

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="nom@hopital.dz"
                        android:inputType="textEmailAddress"
                        android:singleLine="true"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- ══════════════════════════════════ -->
                <!-- SECTION 2 : Rôle                   -->
                <!-- ══════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rôle &amp; Département"
                    android:textColor="#0A3D6B"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"
                    android:background="#1976D2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fonction"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Boutons rôle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="18dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:id="@+id/roleMedecin"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginRight="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/role_selected"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Médecin"
                            android:textColor="#0A3D6B"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:gravity="center"
                            android:text="Praticien hospitalier"
                            android:textColor="#1976D2"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/roleInfirmier"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginLeft="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/role_unselected"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Infirmier(e)"
                            android:textColor="#6B7A8D"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:gravity="center"
                            android:text="Personnel soignant"
                            android:textColor="#9CA3AF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ══════════════════════════════════════════ -->
                <!-- BLOC MÉDECIN (visible par défaut)          -->
                <!-- ══════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/layoutMedecin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <!-- Matricule médecin -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Matricule"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:background="@drawable/input_background"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp">

                        <EditText
                            android:id="@+id/etMatriculeMedecin"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:hint="ex: MED-2024-001"
                            android:inputType="text"
                            android:singleLine="true"
                            android:textColor="#1A1A2E"
                            android:textColorHint="#9CA3AF"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Spécialité -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spécialité"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:background="@drawable/input_background"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp">

                        <Spinner
                            android:id="@+id/spinnerSpecialite"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null" />
                    </LinearLayout>



                </LinearLayout>

                <!-- ══════════════════════════════════════════ -->
                <!-- BLOC INFIRMIER (caché par défaut)          -->
                <!-- ══════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/layoutInfirmier"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Matricule infirmier -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Matricule"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:background="@drawable/input_background"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp">

                        <EditText
                            android:id="@+id/etMatriculeInfirmier"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:hint="ex: INF-2024-001"
                            android:inputType="text"
                            android:singleLine="true"
                            android:textColor="#1A1A2E"
                            android:textColorHint="#9CA3AF"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Service -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Service"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:background="@drawable/input_background"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp">

                        <Spinner
                            android:id="@+id/spinnerService"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null" />
                    </LinearLayout>

                    <!-- Shift -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shift"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/input_background"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp">

                        <Spinner
                            android:id="@+id/spinnerShift"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ══════════════════════════════════ -->
                <!-- SECTION 3 : Sécurité               -->
                <!-- ══════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Sécurité"
                    android:textColor="#0A3D6B"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"
                    android:background="#1976D2" />

                <!-- Mot de passe -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mot de passe"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/input_background"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Minimum 8 caractères"
                        android:inputType="textPassword"
                        android:singleLine="true"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvShowPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="4dp"
                        android:text="Voir"
                        android:textColor="#1976D2"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Confirmer mot de passe -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirmer le mot de passe"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_background"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp">

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Répéter le mot de passe"
                        android:inputType="textPassword"
                        android:singleLine="true"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Indicateur force mot de passe -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="4">

                    <View
                        android:id="@+id/strength1"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_marginRight="3dp"
                        android:layout_weight="1"
                        android:background="#E5383B" />

                    <View
                        android:id="@+id/strength2"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_marginRight="3dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB" />

                    <View
                        android:id="@+id/strength3"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_marginRight="3dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB" />

                    <View
                        android:id="@+id/strength4"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStrengthLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Faible"
                    android:textColor="#E5383B"
                    android:textSize="11sp" />

                <!-- Bouton Signup -->
                <Button
                    android:id="@+id/btnSignup"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/button_primary"
                    android:letterSpacing="0.08"
                    android:text="CRÉER MON COMPTE"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Lien login -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Déjà un compte ? "
                        android:textColor="#6B7A8D"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvGoToLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Se connecter"
                        android:textColor="#0A3D6B"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="© 2026 UrgencePro — Système Hospitalier"
            android:textColor="#9CA3AF"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>